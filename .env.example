# ─── LLM Provider ──────────────────────────────────────────
# REQUIRED: Set exactly ONE provider key.
# DO NOT use Anthropic. Use OpenAI or compatible provider.

# Option A: OpenAI (preferred)
OPENAI_API_KEY=sk-...

# Option B: ZhipuAI / GLM-5.1
# ZHIPUAI_API_KEY=...

# ─── CrewAI Cloud (optional) ───────────────────────────────
CREWAI_API_KEY=pat_rgtmKqq5zz-Ag9bPekZxinpsksAtHeDk4QX-gpbyCuE

# ─── Model selection ───────────────────────────────────────
# Default model used by all agents (no LiteLLM, native provider only)
# Examples: openai/gpt-4o-mini | openai/gpt-4o | zhipuai/glm-4-5
MODEL=openai/gpt-4o-mini

# ─── Execution control ─────────────────────────────────────
DRY_RUN=true

# ─── Asana ─────────────────────────────────────────────────
ASANA_PERSONAL_ACCESS_TOKEN=
# ASANA_MCP_APP_CLIENT_ID=
# ASANA_MCP_APP_CLIENT_SECRET=
# ASANA_WORKSPACE_GID=
# ASANA_PROJECT_GID=

# ─── Webhook server ────────────────────────────────────────
WEBHOOK_PORT=8000
WEBHOOK_HOST=0.0.0.0
# Set automatically after webhook registration:
ASANA_WEBHOOK_SECRET=

# ─── HARD BLOCK ────────────────────────────────────────────
# The application will raise an error if ANTHROPIC_API_KEY is set
# and no other provider key is provided.
# DO NOT set: ANTHROPIC_API_KEY
